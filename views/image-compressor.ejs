<!-- 压缩工具主体 -->
<div class="max-w-4xl mx-auto">
  <div class="bg-white dark:bg-slate-800 rounded-xl p-6 border border-slate-200 dark:border-slate-700 shadow">
    
    <!-- 文件上传区域 -->
    <div id="uploadArea" class="drop-zone">
      <i class="fa-solid fa-cloud-arrow-up text-4xl text-slate-400 mb-3"></i>
      <h3 class="text-lg font-medium mb-1">拖拽图片到此处或点击上传</h3>
      <p class="text-sm text-slate-500 dark:text-slate-400 mb-3">支持 JPG, PNG, WebP 格式，最多可选 10 张</p>
      <p class="text-xs text-slate-400 dark:text-slate-500">单张最大文件大小: 20MB</p>
      <input type="file" id="fileInput" accept="image/*" class="hidden" multiple>
      <button id="browseBtn" class="mt-4 px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-light transition-colors">
        选择图片
      </button>
    </div>

    <!-- 已选图片预览 -->
    <div id="previewArea" class="mt-4 preview-grid hidden">
      <h3 class="font-medium mb-2 col-span-full">已选择 (<span id="fileCount">0</span>/10)</h3>
      <div id="previewList" class="col-span-full"></div>
    </div>

    <!-- 压缩选项 -->
    <div id="optionsArea" class="mt-6 space-y-4 hidden">
      <h3 class="font-medium">压缩选项</h3>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="md:col-span-2"> <!-- 占满整行，适配移动端 -->
          <label class="block text-sm font-medium mb-1">压缩质量</label>
          <input type="range" id="qualitySlider" min="10" max="100" value="80" class="w-full">
          <div class="flex justify-between text-xs text-slate-500 dark:text-slate-400">
            <span>较小 (更快)</span>
            <span id="qualityValue">80%</span>
            <span>较好 (更大)</span>
          </div>
        </div>
        <!-- 移除格式选择下拉框 -->
      </div>

      <button id="compressBtn" class="w-full py-3 bg-secondary text-white rounded-lg hover:opacity-90 transition-opacity font-medium">
        <i class="fa-solid fa-compress-arrows-alt mr-2"></i>
        开始压缩
      </button>
    </div>

    <!-- 进度条 -->
    <div id="progressArea" class="mt-6 hidden">
      <h3 class="font-medium mb-2">压缩进度</h3>
      <div class="progress-bar">
        <div id="progressBarFill" class="progress-bar-fill"></div>
      </div>
      <p id="progressText" class="text-center text-sm mt-2 text-slate-600 dark:text-slate-300">准备中...</p>
      <p id="progressDetail" class="text-center text-xs mt-1 text-slate-500 dark:text-slate-400"></p>
    </div>

    <!-- 结果展示区域 -->
    <div id="resultArea" class="mt-6 hidden">
      <h3 class="font-medium mb-4">压缩结果</h3>
      
      <div id="resultsGrid" class="preview-grid">
        <!-- 压缩结果项将动态插入这里 -->
      </div>

      <div class="mt-6 text-center">
        <button id="downloadAllBtn" class="px-6 py-2.5 bg-primary text-white rounded-lg hover:bg-primary-light transition-colors font-medium">
          <i class="fa-solid fa-download mr-2"></i>
          下载全部
        </button>
        <button id="newCompressionBtn" class="ml-3 px-4 py-2.5 border border-slate-300 dark:border-slate-600 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">
          <i class="fa-solid fa-plus mr-1"></i>
          新压缩
        </button>
      </div>
    </div>
  </div>

  <!-- 特点介绍 -->
  <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-white dark:bg-slate-800 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
      <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
        <i class="fa-solid fa-layer-group"></i>
      </div>
      <h4 class="font-medium mb-1">批量处理</h4>
      <p class="text-sm text-slate-600 dark:text-slate-400">一次性上传最多10张图片，高效完成批量压缩任务。</p>
    </div>
    <div class="bg-white dark:bg-slate-800 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
      <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
        <i class="fa-solid fa-sliders"></i>
      </div>
      <h4 class="font-medium mb-1">灵活调节</h4>
      <p class="text-sm text-slate-600 dark:text-slate-400">可自定义压缩质量，批量统一转换输出格式。</p>
    </div>
    <div class="bg-white dark:bg-slate-800 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
      <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
        <i class="fa-solid fa-bolt"></i>
      </div>
      <h4 class="font-medium mb-1">安全高效</h4>
      <p class="text-sm text-slate-600 dark:text-slate-400">所有处理在本地浏览器完成，保护您的隐私安全。</p>
    </div>
  </div>
</div>

<!-- 预览大图弹窗 (新增) -->
<div id="previewModal" class="fixed inset-0 bg-black/80 flex items-center justify-center z-50 hidden">
  <button id="closeModal" class="absolute top-4 right-4 text-white text-2xl hover:text-gray-300">×</button>
  <img id="modalImage" class="max-w-[90%] max-h-[90vh] object-contain" src="" alt="Preview">
</div>

<script src="/js/jszip.min.js"></script>
<script type="module">
    import Compressor from 'https://cdn.jsdelivr.net/npm/compressorjs@1.2.1/dist/compressor.esm.js';

  // DOM 元素获取
  const fileInput = document.getElementById('fileInput');
  const browseBtn = document.getElementById('browseBtn');
  const uploadArea = document.getElementById('uploadArea');
  const previewArea = document.getElementById('previewArea');
  const previewList = document.getElementById('previewList');
  const fileCount = document.getElementById('fileCount');
  const optionsArea = document.getElementById('optionsArea');
  const compressBtn = document.getElementById('compressBtn');
  const progressArea = document.getElementById('progressArea');
  const progressBarFill = document.getElementById('progressBarFill');
  const progressText = document.getElementById('progressText');
  const progressDetail = document.getElementById('progressDetail');
  const resultArea = document.getElementById('resultArea');
  const resultsGrid = document.getElementById('resultsGrid');
  const downloadAllBtn = document.getElementById('downloadAllBtn');
  const newCompressionBtn = document.getElementById('newCompressionBtn');
  const qualitySlider = document.getElementById('qualitySlider');
  const qualityValue = document.getElementById('qualityValue');
  
  // 新增预览弹窗相关元素
  const previewModal = document.getElementById('previewModal');
  const modalImage = document.getElementById('modalImage');
  const closeModal = document.getElementById('closeModal');

  let selectedFiles = [];
  let compressedResults = [];
  const MAX_FILE_SIZE = 20 * 1024 * 1024; // 20MB 限制
  // 支持的图片格式 (新增)
  const SUPPORTED_FORMATS = ['image/jpeg', 'image/png', 'image/webp'];
  const SUPPORTED_FORMAT_NAMES = ['JPG', 'PNG', 'WebP'];

  // 文件浏览按钮点击事件
  browseBtn.addEventListener('click', () => {
    fileInput.click();
  });

  // 文件输入变化事件
  fileInput.addEventListener('change', (e) => {
    handleFileSelect(Array.from(e.target.files));
  });

  // 拖拽上传事件
  uploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadArea.classList.add('drop-zone--over');
  });

  uploadArea.addEventListener('dragleave', () => {
    uploadArea.classList.remove('drop-zone--over');
  });

  uploadArea.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadArea.classList.remove('drop-zone--over');
    handleFileSelect(Array.from(e.dataTransfer.files));
  });

  // 处理文件选择 (修改：严格校验格式)
  function handleFileSelect(files) {
    // 过滤出图片文件并检查大小和数量
    const validFiles = [];
    files.forEach(file => {
      // 严格校验支持的格式
      if (!SUPPORTED_FORMATS.includes(file.type)) {
        showToast(`文件 ${file.name} 格式不支持（仅支持${SUPPORTED_FORMAT_NAMES.join(', ')}），建议使用<a style="color:#4f46e5;text-decoration: underline;" href="/image-converter">image-converter</a>进行格式转换`, 'error');
        return;
      }
      // 检查文件大小是否超过20MB
      if (file.size > MAX_FILE_SIZE) {
        showToast(`文件 ${file.name} 大小超出20MB限制，已跳过`, 'error');
        return;
      }
      validFiles.push(file);
    });

    // 检查总数量限制
    const totalFiles = selectedFiles.length + validFiles.length;
    if (totalFiles > 10) {
      showToast(`最多只能选择10张图片，当前已选择 ${selectedFiles.length} 张，本次添加 ${validFiles.length} 张，总计超出了限制。`, 'error');
      // 只添加不超限的部分
      const addCount = 10 - selectedFiles.length;
      selectedFiles.push(...validFiles.slice(0, addCount));
    } else {
      selectedFiles.push(...validFiles);
    }

    renderPreviewList();
    updateFileCount();

    if (selectedFiles.length > 0) {
      optionsArea.classList.remove('hidden');
      if (validFiles.length > 0) {
        showToast(`成功添加 ${validFiles.length} 张图片`, 'success');
      }
    }
  }

  // 渲染预览列表
  function renderPreviewList() {
    previewList.innerHTML = '';
    selectedFiles.forEach((file, index) => {
      const reader = new FileReader();
      reader.onload = function(e) {
        const item = document.createElement('div');
        item.className = 'preview-item';
        item.innerHTML = `
          <img src="${e.target.result}" class="preview-img" alt="Preview ${index}">
          <div class="remove-btn" data-index="${index}">&times;</div>
          <div class="preview-info">${file.name}<br>${formatFileSize(file.size)}</div>
        `;
        previewList.appendChild(item);

        // 添加移除按钮事件
        item.querySelector('.remove-btn').addEventListener('click', (e) => {
          e.stopPropagation();
          removeFile(index);
        });
      };
      reader.readAsDataURL(file);
    });
    previewArea.classList.remove('hidden');
  }

  // 移除文件
  function removeFile(index) {
    const removedFileName = selectedFiles[index].name;
    selectedFiles.splice(index, 1);
    renderPreviewList();
    updateFileCount();

    // 添加移除成功提示
    showToast(`已移除 ${removedFileName}`, 'info');

    if (selectedFiles.length === 0) {
      optionsArea.classList.add('hidden');
    }
  }

  // 更新文件计数
  function updateFileCount() {
    fileCount.textContent = selectedFiles.length;
  }

  // 格式化文件大小
  function formatFileSize(bytes) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
  }

  // 质量滑块变化事件
  qualitySlider.addEventListener('input', () => {
    qualityValue.textContent = `${qualitySlider.value}%`;
  });

  // 开始批量压缩按钮事件
  compressBtn.addEventListener('click', async () => {
    if (selectedFiles.length === 0) {
      showToast('请先选择要压缩的图片', 'warning');
      return;
    }

    // 显示进度区域
    progressArea.classList.remove('hidden');
    resultArea.classList.add('hidden');
    resultsGrid.innerHTML = ''; // 清空上次结果
    compressedResults = []; // 重置结果数组

    try {
      let processed = 0;
      const total = selectedFiles.length;

      for (let i = 0; i < selectedFiles.length; i++) {
        const file = selectedFiles[i];
        
        // 更新进度详情
        progressDetail.textContent = `正在处理: ${file.name}`;
        updateProgress(((i) / total) * 100); // 处理前更新进度

        try {
          // 真实压缩（使用compressor.js）
          const compressedBlob = await simulateCompression(file, qualitySlider.value);
          const compressedUrl = URL.createObjectURL(compressedBlob);
          
          // 存储结果
          const originalSize = file.size;
          const compressedSize = compressedBlob.size;
          const reduction = ((1 - compressedSize / originalSize) * 100).toFixed(1);
          
          compressedResults.push({
            originalFile: file,
            compressedBlob: compressedBlob,
            compressedUrl: compressedUrl,
            originalSize: originalSize,
            compressedSize: compressedSize,
            reduction: reduction
          });

          processed++;
          updateProgress((processed / total) * 100); // 处理完成后更新进度
        } catch (fileError) {
          console.error(`压缩文件 ${file.name} 失败:`, fileError);
          showToast(`文件 ${file.name} 压缩失败，跳过该文件`, 'error');
          processed++;
          updateProgress((processed / total) * 100);
        }
      }

      progressText.textContent = '全部压缩完成！';
      progressDetail.textContent = '';
      
      if (compressedResults.length > 0) {
        showToast(`成功压缩 ${compressedResults.length} 张图片（${selectedFiles.length - compressedResults.length} 张失败）`, 'success');
        renderResults();
        // 显示结果区域
        setTimeout(() => {
          resultArea.classList.remove('hidden');
          progressArea.classList.add('hidden');
        }, 500);
      } else {
        showToast('所有图片压缩失败，请检查文件格式或重试', 'error');
        progressArea.classList.add('hidden');
      }

    } catch (error) {
      console.error('批量压缩失败:', error);
      progressText.textContent = '压缩过程中出现错误，请重试。';
      progressDetail.textContent = '';
      showToast('压缩过程中出现错误，请重试', 'error');
    }
  });

  // 真实压缩函数 (修改：移除格式参数，固定使用原格式)
  async function simulateCompression(file, quality) {
    return new Promise((resolve, reject) => {
      // 转换质量值（compressor.js 接受 0.0 - 1.0 范围）
      const compressQuality = parseInt(quality) / 100;
      
      // 固定使用原文件格式
      const targetMimeType = file.type;

      // 使用 compressor.js 压缩图片
      new Compressor(file, {
        quality: compressQuality, // 压缩质量
        mimeType: targetMimeType, // 输出格式（固定原格式）
        maxWidth: Infinity, // 不限制宽度
        maxHeight: Infinity, // 不限制高度
        convertSize: 0, // 强制转换格式（即使文件小）
        success(result) {
          resolve(result); // 返回压缩后的 Blob 对象
        },
        error(err) {
          reject(err); // 抛出错误
        }
      });
    });
  }

  // 渲染压缩结果 (修改：增强预览功能，适配移动端)
  function renderResults() {
      resultsGrid.innerHTML = '';
      compressedResults.forEach((result, index) => {
          const item = document.createElement('div');
          item.className = 'preview-item';
          item.innerHTML = `
            <img src="${result.compressedUrl}" class="preview-img cursor-pointer" alt="Compressed ${index}" data-url="${result.compressedUrl}">
            <div class="preview-info">
              ${result.originalFile.name}<br>
              <span class="text-green-600 dark:text-green-400">-${result.reduction}%</span><br>
              ${formatFileSize(result.compressedSize)}
            </div>
          `;
          resultsGrid.appendChild(item);

          // 添加点击预览大图事件 (新增)
          const img = item.querySelector('.preview-img');
          img.addEventListener('click', () => {
            modalImage.src = result.compressedUrl;
            previewModal.classList.remove('hidden');
          });
      });
  }

  // 更新进度
  function updateProgress(percent) {
    progressBarFill.style.width = `${percent}%`;
    progressText.textContent = `正在压缩... ${Math.round(percent)}%`;
  }

  // 下载全部按钮事件
  downloadAllBtn.addEventListener('click', async () => {
    if (compressedResults.length === 0) {
      showToast('暂无压缩文件可下载', 'warning');
      return;
    }

    // 单张图片直接下载
    if (compressedResults.length === 1) {
      const result = compressedResults[0];
      const a = document.createElement('a');
      a.href = result.compressedUrl;
      a.download = `compressed_${result.originalFile.name}`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      showToast(`开始下载 ${result.originalFile.name}`, 'success');
      
      // 稍后清理 URL 对象
      setTimeout(() => {
        URL.revokeObjectURL(result.compressedUrl);
      }, 1000);
      return;
    }

    // 多张图片打包为ZIP下载
    try {
      showToast('正在生成压缩包，请稍候...', 'info');
      const zip = new JSZip();
      
      // 向压缩包中添加所有压缩后的图片
      compressedResults.forEach((result, index) => {
        const fileName = `compressed_${index+1}_${result.originalFile.name}`;
        // 将Blob添加到ZIP
        zip.file(fileName, result.compressedBlob);
      });

      // 生成ZIP文件
      const zipContent = await zip.generateAsync({
        type: 'blob',
        compression: 'DEFLATE',
        compressionOptions: { level: 6 }
      });

      // 创建下载链接
      const zipUrl = URL.createObjectURL(zipContent);
      const a = document.createElement('a');
      a.href = zipUrl;
      a.download = `compressed_images_${new Date().getTime()}.zip`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);

      showToast(`开始下载压缩包（包含 ${compressedResults.length} 张图片）`, 'success');

      // 清理URL对象
      setTimeout(() => {
        URL.revokeObjectURL(zipUrl);
        compressedResults.forEach(result => {
          URL.revokeObjectURL(result.compressedUrl);
        });
      }, 1000);
    } catch (error) {
      console.error('生成压缩包失败:', error);
      showToast('生成压缩包失败，请尝试单独下载', 'error');
    }
  });

  // 新压缩按钮事件
  newCompressionBtn.addEventListener('click', () => {
    // 重置所有状态
    fileInput.value = '';
    selectedFiles = [];
    compressedResults = [];
    
    previewList.innerHTML = '';
    previewArea.classList.add('hidden');
    optionsArea.classList.add('hidden');
    progressArea.classList.add('hidden');
    resultArea.classList.add('hidden');
    resultsGrid.innerHTML = '';
    
    updateFileCount();
    
    // 添加重置提示
    showToast('已重置，可开始新的压缩任务', 'info');
  });

  // 预览弹窗关闭事件 (新增)
  closeModal.addEventListener('click', () => {
    previewModal.classList.add('hidden');
    modalImage.src = ''; // 清空图片地址
  });

  // 点击弹窗背景关闭 (新增，适配移动端操作)
  previewModal.addEventListener('click', (e) => {
    if (e.target === previewModal) {
      previewModal.classList.add('hidden');
      modalImage.src = '';
    }
  });


</script>

<style>
/* 基础样式补充 */
.drop-zone {
  border: 2px dashed #e2e8f0;
  border-radius: 8px;
  padding: 2rem;
  text-align: center;
  cursor: pointer;
  transition: border-color 0.2s ease;
}
.drop-zone--over {
  border-color: #3b82f6;
  background-color: #f0f9ff;
}
.preview-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
  gap: 1rem;
}
.preview-item {
  position: relative;
  border: 1px solid #e2e8f0;
  border-radius: 4px;
  overflow: hidden;
}
.preview-img {
  width: 100%;
  height: 100px;
  object-fit: cover;
}
.remove-btn {
  position: absolute;
  top: 2px;
  right: 2px;
  width: 20px;
  height: 20px;
  background-color: rgba(0,0,0,0.5);
  color: white;
  text-align: center;
  line-height: 20px;
  border-radius: 50%;
  cursor: pointer;
  font-size: 14px;
}
.preview-info {
  padding: 4px;
  font-size: 12px;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.progress-bar {
  height: 8px;
  width: 100%;
  background-color: #e2e8f0;
  border-radius: 4px;
  overflow: hidden;
}
.progress-bar-fill {
  height: 100%;
  width: 0%;
  background-color: #3b82f6;
  transition: width 0.3s ease;
}
/* 主题色样式 */
.bg-primary {
  background-color: #3b82f6;
}
.bg-primary-light {
  background-color: #60a5fa;
}
.bg-secondary {
  background-color: #10b981;
}

/* 新增：预览弹窗样式（适配移动端） */
#previewModal {
  touch-action: none; /* 防止移动端触摸事件冲突 */
}
.cursor-pointer {
  cursor: pointer;
}

/* 移动端适配优化 */
@media (max-width: 768px) {
  .preview-grid {
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 0.5rem;
  }
  .preview-img {
    height: 80px;
  }
  .drop-zone {
    padding: 1.5rem;
  }
  #downloadAllBtn, #newCompressionBtn {
    display: block;
    width: 100%;
    margin: 0.5rem 0;
  }
  #newCompressionBtn {
    margin-left: 0 !important;
  }
}
</style>