<!-- 视频转音频工具主体 -->
<div class="max-w-4xl mx-auto">
  <div class="bg-white dark:bg-slate-800 rounded-xl p-6 border border-slate-200 dark:border-slate-700 shadow">
    
    <!-- 文件上传区域 -->
    <div id="uploadArea" class="drop-zone border-2 border-dashed border-slate-200 dark:border-slate-700 rounded-lg p-8 text-center cursor-pointer transition-colors duration-200">
      <i class="fa-solid fa-video text-4xl text-slate-400 mb-3"></i>
      <h3 class="text-lg font-medium mb-1">拖拽视频到此处或点击上传</h3>
      <p class="text-sm text-slate-500 dark:text-slate-400 mb-3">支持 MP4, WebM, AVI, MOV 格式</p>
      <p class="text-xs text-slate-400 dark:text-slate-500">单个文件最大大小: 100MB</p>
      <input type="file" id="fileInput" accept="video/*" class="hidden">
      <button id="browseBtn" class="mt-4 px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-light transition-colors">
        选择视频
      </button>
    </div>

    <!-- 视频预览和提取选项 -->
    <div id="previewArea" class="mt-6 hidden">
      <h3 class="font-medium mb-3">视频预览与提取选项</h3>
      
      <div class="bg-slate-100 dark:bg-slate-700 rounded-lg p-4">
        <!-- 视频播放器 -->
        <div class="mb-4">
          <video id="videoPlayer" controls class="w-full max-h-64">
            您的浏览器不支持视频播放。
           </video>
        </div>
        
        <!-- 提取选项 -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
          <div>
            <label class="block text-sm font-medium mb-1">输出音频格式</label>
            <select id="outputFormat" class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-slate-100">
              <option value="mp3">MP3</option>
              <option value="wav">WAV</option>
              <option value="ogg">OGG</option>
              <option value="aac">AAC</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">音频质量</label>
            <select id="audioQuality" class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-slate-100">
              <option value="low">低质量</option>
              <option value="medium" selected>中等质量</option>
              <option value="high">高质量</option>
            </select>
          </div>
        </div>
        
        <button id="extractBtn" class="w-full py-3 bg-primary text-white rounded-lg hover:opacity-90 transition-opacity font-medium">
          <i class="fa-solid fa-volume-up mr-2"></i>
          开始提取音频
        </button>
      </div>
    </div>

    <!-- 进度条 -->
    <div id="progressArea" class="mt-6 hidden">
      <h3 class="font-medium mb-2">提取进度</h3>
      <div class="h-3 w-full bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden">
        <div id="progressBarFill" class="h-full bg-primary dark:bg-primary-light w-0 transition-all duration-300"></div>
      </div>
      <p id="progressText" class="text-center text-sm mt-2 text-slate-600 dark:text-slate-300">准备中...</p>
    </div>

    <!-- 结果展示区域 -->
    <div id="resultArea" class="mt-6 hidden">
      <h3 class="font-medium mb-4">提取结果</h3>
      
      <div class="bg-slate-100 dark:bg-slate-700 rounded-lg p-4">
        <!-- 提取后音频预览 -->
        <div class="mb-4">
          <h4 class="text-sm font-medium mb-2">提取后音频</h4>
          <audio id="extractedAudio" controls class="w-full">
            您的浏览器不支持音频播放。
           </audio>
        </div>
        
        <div class="flex space-x-2">
          <button id="downloadBtn" class="flex-1 py-2.5 bg-primary text-white rounded-lg hover:bg-primary-light transition-colors font-medium">
            <i class="fa-solid fa-download mr-2"></i>
            下载
          </button>
          <button id="newExtractBtn" class="flex-1 py-2.5 border border-slate-300 dark:border-slate-600 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">
            <i class="fa-solid fa-plus mr-1"></i>
            新提取
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- 特点介绍 -->
  <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-white dark:bg-slate-800 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
      <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
        <i class="fa-solid fa-file-video"></i>
      </div>
      <h4 class="font-medium mb-1">多种格式</h4>
      <p class="text-sm text-slate-600 dark:text-slate-400">支持 MP4、WebM、AVI、MOV 等多种视频格式。</p>
    </div>
    <div class="bg-white dark:bg-slate-800 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
      <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
        <i class="fa-solid fa-bolt"></i>
      </div>
      <h4 class="font-medium mb-1">快速提取</h4>
      <p class="text-sm text-slate-600 dark:text-slate-400">本地浏览器处理，无需上传服务器，提取速度快。</p>
    </div>
    <div class="bg-white dark:bg-slate-800 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
      <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
        <i class="fa-solid fa-lock"></i>
      </div>
      <h4 class="font-medium mb-1">安全隐私</h4>
      <p class="text-sm text-slate-600 dark:text-slate-400">所有处理在本地完成，保护您的视频文件安全。</p>
    </div>
  </div>
</div>
