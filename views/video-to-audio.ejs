<script>
  // DOM 元素获取
  const fileInput = document.getElementById('fileInput');
  const browseBtn = document.getElementById('browseBtn');
  const uploadArea = document.getElementById('uploadArea');
  const previewArea = document.getElementById('previewArea');
  const videoPlayer = document.getElementById('videoPlayer');
  const outputFormat = document.getElementById('outputFormat');
  const audioQuality = document.getElementById('audioQuality');
  const extractBtn = document.getElementById('extractBtn');
  const progressArea = document.getElementById('progressArea');
  const progressBarFill = document.getElementById('progressBarFill');
  const progressText = document.getElementById('progressText');
  const resultArea = document.getElementById('resultArea');
  const extractedAudio = document.getElementById('extractedAudio');
  const downloadBtn = document.getElementById('downloadBtn');
  const newExtractBtn = document.getElementById('newExtractBtn');

  let selectedFile = null;
  let audioContext = null;

  // 文件浏览按钮点击事件
  browseBtn.addEventListener('click', () => {
    fileInput.click();
  });

  // 文件输入变化事件
  fileInput.addEventListener('change', (e) => {
    if (e.target.files.length > 0) {
      handleFileSelect(e.target.files[0]);
    }
  });

  // 拖拽上传事件
  uploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadArea.classList.add('border-primary', 'bg-primary/10');
  });

  uploadArea.addEventListener('dragleave', () => {
    uploadArea.classList.remove('border-primary', 'bg-primary/10');
  });

  uploadArea.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadArea.classList.remove('border-primary', 'bg-primary/10');
    if (e.dataTransfer.files.length > 0) {
      handleFileSelect(e.dataTransfer.files[0]);
    }
  });

  // 处理文件选择
  function handleFileSelect(file) {
    if (!file.type.startsWith('video/')) {
      showToast('请选择视频文件', 'error');
      return;
    }

    if (file.size > 100 * 1024 * 1024) {
      showToast('文件大小超出100MB限制', 'error');
      return;
    }

    selectedFile = file;

    // 设置视频播放器
    const objectURL = URL.createObjectURL(file);
    videoPlayer.src = objectURL;

    // 显示预览区域
    previewArea.classList.remove('hidden');
    showToast('视频加载成功', 'success');
  }

  // 使用Web Audio API和MediaRecorder从视频中提取音频
  async function extractAudio(videoFile, outputFormat, quality) {
    return new Promise((resolve, reject) => {
      try {
        // 创建视频元素
        const video = document.createElement('video');
        video.src = URL.createObjectURL(videoFile);
        video.muted = true;

        video.onloadedmetadata = () => {
          // 创建音频上下文
          if (!audioContext) {
            audioContext = new (window.AudioContext || window.webkitAudioContext)();
          }

          // 创建媒体元素源
          const mediaElementSource = audioContext.createMediaElementSource(video);
          
          // 创建媒体流目标
          const destination = audioContext.createMediaStreamDestination();
          mediaElementSource.connect(destination);

          // 配置MIME类型
          let mimeType = 'audio/ogg';
          if (outputFormat === 'mp3') {
            mimeType = 'audio/mp3';
          } else if (outputFormat === 'wav') {
            mimeType = 'audio/wav';
          } else if (outputFormat === 'aac') {
            mimeType = 'audio/aac';
          }

          // 检查浏览器是否支持该MIME类型
          if (!MediaRecorder.isTypeSupported(mimeType)) {
            mimeType = 'audio/ogg';
          }

          // 创建媒体记录器
          const mediaRecorder = new MediaRecorder(destination.stream, { mimeType });
          const chunks = [];

          mediaRecorder.ondataavailable = (event) => {
            if (event.data.size > 0) {
              chunks.push(event.data);
            }
          };

          mediaRecorder.onstop = () => {
            const blob = new Blob(chunks, { type: mimeType });
            resolve(blob);
          };

          mediaRecorder.onerror = (error) => {
            reject(error);
          };

          // 开始录制
          mediaRecorder.start();

          // 开始播放视频
          video.play();

          // 视频结束后停止录制
          video.onended = () => {
            setTimeout(() => {
              mediaRecorder.stop();
            }, 100);
          };
        };

        video.onerror = (error) => {
          reject(error);
        };

      } catch (error) {
        reject(error);
      }
    });
  }

  // 开始提取按钮事件
  extractBtn.addEventListener('click', async () => {
    if (!selectedFile) {
      showToast('请先选择视频文件', 'warning');
      return;
    }

    progressArea.classList.remove('hidden');
    resultArea.classList.add('hidden');

    try {
      progressText.textContent = '正在提取音频...';
      progressBarFill.style.width = '0%';

      // 模拟进度
      let progress = 0;
      const progressInterval = setInterval(() => {
        progress += 10;
        progressBarFill.style.width = `${progress}%`;
        if (progress >= 90) {
          clearInterval(progressInterval);
        }
      }, 100);

      // 执行音频提取
      const outputFormatValue = outputFormat.value;
      const extractedBlob = await extractAudio(selectedFile, outputFormatValue, audioQuality.value);
      const extractedUrl = URL.createObjectURL(extractedBlob);

      // 更新进度
      clearInterval(progressInterval);
      progressBarFill.style.width = '100%';
      progressText.textContent = '提取完成！';

      // 设置提取后音频播放器
      extractedAudio.src = extractedUrl;

      // 显示结果区域
      setTimeout(() => {
        resultArea.classList.remove('hidden');
        progressArea.classList.add('hidden');
        showToast('音频提取成功', 'success');
      }, 500);

      // 下载按钮事件
      downloadBtn.onclick = () => {
        const a = document.createElement('a');
        a.href = extractedUrl;
        const fileName = selectedFile.name.replace(/\.[^/.]+$/, `_audio.${extractedBlob.type.split('/')[1]}`);
        a.download = fileName;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        showToast(`开始下载 ${fileName}`, 'success');
      };

    } catch (error) {
      console.error('提取失败:', error);
      progressText.textContent = '提取失败，请重试。';
      showToast('提取失败，请重试', 'error');
    }
  });

  // 新提取按钮事件
  newExtractBtn.addEventListener('click', () => {
    fileInput.value = '';
    selectedFile = null;
    
    videoPlayer.src = '';
    extractedAudio.src = '';
    
    previewArea.classList.add('hidden');
    progressArea.classList.add('hidden');
    resultArea.classList.add('hidden');
    
    showToast('已重置，可开始新的提取任务', 'info');
  });
</script>