

<!-- 热门工具 -->
<section class="mb-10">
  <h2 class="text-xl font-bold mb-5 flex items-center gap-2 before:content-[''] before:w-1.5 before:h-6 before:bg-primary before:rounded-sm">热门推荐工具</h2>
  <div class="tool-grid">
    <% tools.forEach(tool => { %>
    <a href="/<%= tool.id %>" class="bg-white dark:bg-slate-800 rounded-xl p-5 border border-slate-200 dark:border-slate-700 shadow card-hover">
      <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary to-primary-light flex items-center justify-center text-white text-xl mb-3">
        <i class="fa-solid <%= tool.icon %>"></i>
      </div>
      <h3 class="text-lg font-semibold mb-1"><%= tool.title %></h3>
      <p class="text-sm text-slate-500 dark:text-slate-400"><%= tool.description %></p>
    </a>
    <% }); %>
  </div>
</section>

<!-- 开发工具 -->
<section>
