<script>

  // Tab切换功能
  const tabBtns = document.querySelectorAll('.tab-btn');
  const panels = document.querySelectorAll('.panel');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      // 切换按钮状态
      tabBtns.forEach(t => {
        t.classList.remove('bg-primary', 'text-white');
        t.classList.add('hover:bg-slate-100', 'dark:hover:bg-slate-700');
      });
      // 给当前点击的按钮设置激活样式
      btn.classList.remove('hover:bg-slate-100', 'dark:hover:bg-slate-700');
      btn.classList.add('bg-primary', 'text-white');

      // 显示对应面板
      const targetPanelId = btn.id.replace('Tab', 'Panel');
      panels.forEach(panel => {
        panel.classList.add('hidden');
        if (panel.id === targetPanelId) {
          panel.classList.remove('hidden');
          panel.classList.add('active');
        }
      });
    });
  });

  // 编码功能
  document.getElementById('encodeBtn').addEventListener('click', () => {
    const btn = document.getElementById('encodeBtn');
    const originalText = btn.innerHTML;
    const input = document.getElementById('encodeInput').value.trim();

    // 非空校验
    if (!input) {
      showToast('请输入要编码的文本内容，内容不能为空', 'warning');
      // 添加输入框抖动效果
      const inputEl = document.getElementById('encodeInput');
      inputEl.classList.add('animate-shake');
      setTimeout(() => {
        inputEl.classList.remove('animate-shake');
      }, 500);
      return;
    }

    // 显示处理状态
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i>编码中...';
    btn.classList.add('btn-processing');

    setTimeout(() => {
      try {
        const encoded = btoa(encodeURIComponent(input).replace(/%([0-9A-F]{2})/g, (match, p1) => String.fromCharCode('0x' + p1)));
        document.getElementById('encodeOutput').value = encoded;
        // 恢复按钮状态
        btn.innerHTML = originalText;
        btn.classList.remove('btn-processing');
        // 成功提示
        showToast('编码成功', 'success');
        // 添加成功动画
        btn.style.backgroundColor = '#10b981';
        setTimeout(() => {
          btn.style.backgroundColor = '';
        }, 1000);
      } catch (error) {
        // 恢复按钮状态
        btn.innerHTML = originalText;
        btn.classList.remove('btn-processing');
        // 添加错误动画
        btn.style.backgroundColor = '#ef4444';
        setTimeout(() => {
          btn.style.backgroundColor = '';
        }, 1000);
        // 错误提示
        showToast('编码失败，请检查输入内容', 'error');
      }
    }, 300); // 模拟处理时间
  });

  // 解码功能
  document.getElementById('decodeBtn').addEventListener('click', () => {
    const btn = document.getElementById('decodeBtn');
    const originalText = btn.innerHTML;
    const input = document.getElementById('decodeInput').value.trim();

    // 非空校验
    if (!input) {
      showToast('请输入要解码的Base64字符串，内容不能为空', 'warning');
      // 添加输入框抖动效果
      const inputEl = document.getElementById('decodeInput');
      inputEl.classList.add('animate-shake');
      setTimeout(() => {
        inputEl.classList.remove('animate-shake');
      }, 500);
      return;
    }

    // 显示处理状态
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i>解码中...';
    btn.classList.add('btn-processing');

    setTimeout(() => {
      try {
        const decoded = decodeURIComponent(Array.prototype.map.call(atob(input), c => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2)).join(''));
        document.getElementById('decodeOutput').value = decoded;
        // 恢复按钮状态
        btn.innerHTML = originalText;
        btn.classList.remove('btn-processing');
        // 成功提示
        showToast('解码成功', 'success');
        // 添加成功动画
        btn.style.backgroundColor = '#10b981';
        setTimeout(() => {
          btn.style.backgroundColor = '';
        }, 1000);
      } catch (error) {
        // 恢复按钮状态
        btn.innerHTML = originalText;
        btn.classList.remove('btn-processing');
        // 添加错误动画
        btn.style.backgroundColor = '#ef4444';
        setTimeout(() => {
          btn.style.backgroundColor = '';
        }, 1000);
        // 错误提示
        showToast('解码失败，请检查输入的Base64字符串是否正确', 'error');
      }
    }, 300); // 模拟处理时间
  });

  // 清空功能
  document.getElementById('clearEncodeBtn').addEventListener('click', () => {
    document.getElementById('encodeInput').value = '';
    document.getElementById('encodeOutput').value = '';
    showToast('已清空编码内容', 'info');
  });

  document.getElementById('clearDecodeBtn').addEventListener('click', () => {
    document.getElementById('decodeInput').value = '';
    document.getElementById('decodeOutput').value = '';
    showToast('已清空解码内容', 'info');
  });

  // 复制功能
  document.getElementById('copyEncodeBtn').addEventListener('click', () => {
    const output = document.getElementById('encodeOutput');
    if (output.value) {
      output.select();
      document.execCommand('copy');
      // 添加成功反馈
      const btn = document.getElementById('copyEncodeBtn');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<i class="fa-solid fa-check mr-2"></i>已复制';
      btn.style.backgroundColor = '#10b981';
      setTimeout(() => {
        btn.innerHTML = originalText;
        btn.style.backgroundColor = '';
      }, 1000);
      showToast('编码结果已复制', 'success');
    } else {
      showToast('没有内容可供复制', 'warning');
    }
  });

  document.getElementById('copyDecodeBtn').addEventListener('click', () => {
    const output = document.getElementById('decodeOutput');
    if (output.value) {
      output.select();
      document.execCommand('copy');
      // 添加成功反馈
      const btn = document.getElementById('copyDecodeBtn');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<i class="fa-solid fa-check mr-2"></i>已复制';
      btn.style.backgroundColor = '#10b981';
      setTimeout(() => {
        btn.innerHTML = originalText;
        btn.style.backgroundColor = '';
      }, 1000);
      showToast('解码结果已复制', 'success');
    } else {
      showToast('没有内容可供复制', 'warning');
    }
  });

  // 下载功能
  function downloadFile(content, filename) {
    const blob = new Blob([content], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  }

  document.getElementById('downloadEncodeBtn').addEventListener('click', () => {
    const content = document.getElementById('encodeOutput').value;
    if (content) {
      downloadFile(content, 'base64_encoded.txt');
      // 添加成功反馈
      const btn = document.getElementById('downloadEncodeBtn');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<i class="fa-solid fa-check mr-2"></i>已下载';
      btn.style.backgroundColor = '#10b981';
      setTimeout(() => {
        btn.innerHTML = originalText;
        btn.style.backgroundColor = '';
      }, 1000);
      showToast('编码结果已下载', 'success');
    } else {
      showToast('没有内容可供下载', 'warning');
    }
  });

  document.getElementById('downloadDecodeBtn').addEventListener('click', () => {
    const content = document.getElementById('decodeOutput').value;
    if (content) {
      downloadFile(content, 'decoded_content.txt');
      // 添加成功反馈
      const btn = document.getElementById('downloadDecodeBtn');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<i class="fa-solid fa-check mr-2"></i>已下载';
      btn.style.backgroundColor = '#10b981';
      setTimeout(() => {
        btn.innerHTML = originalText;
        btn.style.backgroundColor = '';
      }, 1000);
      showToast('解码结果已下载', 'success');
    } else {
      showToast('没有内容可供下载', 'warning');
    }
  });
</script>

