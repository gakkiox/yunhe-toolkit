<script>
  // DOM 元素获取
  const fileInput = document.getElementById('fileInput');
  const browseBtn = document.getElementById('browseBtn');
  const uploadArea = document.getElementById('uploadArea');
  const previewArea = document.getElementById('previewArea');
  const previewList = document.getElementById('previewList');
  const fileCount = document.getElementById('fileCount');
  const optionsArea = document.getElementById('optionsArea');
  const convertBtn = document.getElementById('convertBtn');
  const progressArea = document.getElementById('progressArea');
  const progressBarFill = document.getElementById('progressBarFill');
  const progressText = document.getElementById('progressText');
  const progressDetail = document.getElementById('progressDetail');
  const resultArea = document.getElementById('resultArea');
  const resultsGrid = document.getElementById('resultsGrid');
  const downloadAllBtn = document.getElementById('downloadAllBtn');
  const newConversionBtn = document.getElementById('newConversionBtn');
  const qualitySlider = document.getElementById('qualitySlider');
  const qualityValue = document.getElementById('qualityValue');
  const formatSelect = document.getElementById('formatSelect');

  let selectedFiles = [];
  let convertedResults = [];

  // 文件浏览按钮点击事件
  browseBtn.addEventListener('click', () => {
    fileInput.click();
  });

  // 文件输入变化事件
  fileInput.addEventListener('change', (e) => {
    handleFileSelect(Array.from(e.target.files));
  });

  // 拖拽上传事件
  uploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadArea.classList.add('drop-zone--over');
  });

  uploadArea.addEventListener('dragleave', () => {
    uploadArea.classList.remove('drop-zone--over');
  });

  uploadArea.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadArea.classList.remove('drop-zone--over');
    handleFileSelect(Array.from(e.dataTransfer.files));
  });

  // 处理文件选择
  function handleFileSelect(files) {
    // 过滤出支持的图片文件并检查数量
    const validTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp', 'image/gif'];
    const imageFiles = files.filter(file => 
      validTypes.includes(file.type.toLowerCase()) && 
      file.size <= 10 * 1024 * 1024
    );
    
    const totalFiles = selectedFiles.length + imageFiles.length;
    
    if (totalFiles > 10) {
      // 替换alert为showToast
      showToast(`最多只能选择10张图片，当前已选择 ${selectedFiles.length} 张，本次添加 ${imageFiles.length} 张，总计超出了限制。`, 'error');
      return;
    }

    // 添加新文件到数组
    selectedFiles.push(...imageFiles.slice(0, 10 - selectedFiles.length));

    renderPreviewList();
    updateFileCount();

    if (selectedFiles.length > 0) {
      optionsArea.classList.remove('hidden');
      // 添加成功提示
      showToast(`成功添加 ${imageFiles.length} 张图片`, 'success');
    }
  }

  // 渲染预览列表
  function renderPreviewList() {
    previewList.innerHTML = '';
    selectedFiles.forEach((file, index) => {
      const reader = new FileReader();
      reader.onload = function(e) {
        const item = document.createElement('div');
        item.className = 'preview-item';
        item.innerHTML = `
          <img src="${e.target.result}" class="preview-img" alt="Preview ${index}">
          <div class="remove-btn" data-index="${index}">&times;</div>
          <div class="preview-info">${file.name}<br>${formatFileSize(file.size)}</div>
        `;
        previewList.appendChild(item);

        // 添加移除按钮事件
        item.querySelector('.remove-btn').addEventListener('click', (e) => {
          e.stopPropagation();
          removeFile(index);
        });
      };
      reader.readAsDataURL(file);
    });
    previewArea.classList.remove('hidden');
  }

  // 移除文件
  function removeFile(index) {
    const removedFileName = selectedFiles[index].name;
    selectedFiles.splice(index, 1);
    renderPreviewList();
    updateFileCount();

    // 添加移除成功提示
    showToast(`已移除 ${removedFileName}`, 'info');

    if (selectedFiles.length === 0) {
      optionsArea.classList.add('hidden');
    }
  }

  // 更新文件计数
  function updateFileCount() {
    fileCount.textContent = selectedFiles.length;
  }

  // 格式化文件大小
  function formatFileSize(bytes) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
  }

  // 质量滑块变化事件
  qualitySlider.addEventListener('input', () => {
    qualityValue.textContent = `${qualitySlider.value}%`;
  });

  // 开始批量转换按钮事件
  convertBtn.addEventListener('click', async () => {
    if (selectedFiles.length === 0) {
      showToast('请先选择要转换的图片', 'warning');
      return;
    }

    const outputFormat = formatSelect.value;
    const quality = qualitySlider.value / 100;

    // 显示进度区域
    progressArea.classList.remove('hidden');
    resultArea.classList.add('hidden');
    resultsGrid.innerHTML = ''; // 清空上次结果
    
    convertedResults = []; // 重置结果数组

    try {
      let processed = 0;
      const total = selectedFiles.length;

      for (let i = 0; i < selectedFiles.length; i++) {
        const file = selectedFiles[i];
        
        // 更新进度详情
        progressDetail.textContent = `正在转换: ${file.name}`;
        
        // 更新进度条
        updateProgress(((i) / total) * 100);

        // 实际的图片转换逻辑 (模拟)
        await new Promise(resolve => setTimeout(resolve, 600)); // 模拟单张图片处理耗时

        // 尝试在Canvas中绘制图片进行转换
        const convertedBlob = await convertImageWithCanvas(file, outputFormat, quality);
        const convertedUrl = URL.createObjectURL(convertedBlob);
        
        // 存储结果
        const originalSize = file.size;
        const convertedSize = convertedBlob.size;
        const extension = outputFormat.toUpperCase();
        
        convertedResults.push({
          originalFile: file,
          convertedBlob: convertedBlob,
          convertedUrl: convertedUrl,
          originalSize: originalSize,
          convertedSize: convertedSize,
          extension: extension
        });

        processed++;
        updateProgress((processed / total) * 100);
      }

      progressText.textContent = '全部转换完成！';
      progressDetail.textContent = '';
      showToast(`成功转换 ${convertedResults.length} 张图片`, 'success');

      // 渲染结果
      renderResults();

      // 显示结果区域
      setTimeout(() => {
        resultArea.classList.remove('hidden');
        progressArea.classList.add('hidden');
      }, 500);

    } catch (error) {
      // 替换console.error为showToast
      showToast(`批量转换失败: ${error.message}`, 'error');
      console.error('批量转换失败:', error); // 保留控制台日志便于调试
      progressText.textContent = '转换过程中出现错误，请重试。';
      progressDetail.textContent = '';
    }
  });

  // 使用Canvas进行图片格式转换
  async function convertImageWithCanvas(file, outputFormat, quality) {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = function(event) {
        const img = new Image();
        img.onload = function() {
          const canvas = document.createElement('canvas');
          const ctx = canvas.getContext('2d');
          
          // 设置画布尺寸与原图一致
          canvas.width = img.width;
          canvas.height = img.height;
          
          // 绘制图片到画布
          ctx.drawImage(img, 0, 0);
          
          try {
            // 根据目标格式导出
            let mimeType = 'image/' + outputFormat;
            if (outputFormat === 'jpg' || outputFormat === 'jpeg') {
              mimeType = 'image/jpeg'; // 确保JPG类型正确
            } else if (outputFormat === 'png') {
              mimeType = 'image/png'; // PNG不需要质量参数
            } else if (outputFormat === 'webp') {
              mimeType = 'image/webp';
            } else if (outputFormat === 'gif') {
              // GIF无法通过toDataURL直接转换，这里模拟一个结果
              // 在实际应用中，需要引入gif.js等库来处理
              mimeType = 'image/gif';
            }

            // 导出为blob
            canvas.toBlob(
              function(blob) {
                if (blob) {
                  resolve(blob);
                } else {
                  // 如果转换失败，返回原文件的blob（模拟）
                  showToast(`图片 ${file.name} 转换失败，使用原文件`, 'warning');
                  resolve(file.slice(0));
                }
              },
              mimeType,
              outputFormat === 'png' ? undefined : quality // PNG不需要质量参数
            );
          } catch (e) {
            console.error('Canvas转换错误:', e);
            showToast(`图片 ${file.name} 转换出错: ${e.message}`, 'error');
            // 转换失败时返回原文件的blob（模拟）
            resolve(file.slice(0));
          }
        };
        img.onerror = function() {
          const errorMsg = `无法加载图片 ${file.name}`;
          showToast(errorMsg, 'error');
          reject(new Error(errorMsg));
        };
        img.src = event.target.result;
      };
      reader.onerror = function() {
        const errorMsg = `无法读取文件 ${file.name}`;
        showToast(errorMsg, 'error');
        reject(new Error(errorMsg));
      };
      reader.readAsDataURL(file);
    });
  }

  // 渲染转换结果
  function renderResults() {
      resultsGrid.innerHTML = '';
      convertedResults.forEach((result, index) => {
          const item = document.createElement('div');
          item.className = 'preview-item';
          item.innerHTML = `
            <img src="${result.convertedUrl}" class="preview-img" alt="Converted ${index}">
            <div class="preview-info">
              ${result.originalFile.name.replace(/\.[^/.]+$/, "")}.${result.extension}<br>
              ${formatFileSize(result.convertedSize)}
            </div>
          `;
          resultsGrid.appendChild(item);
      });
  }

  // 更新进度
  function updateProgress(percent) {
    progressBarFill.style.width = `${percent}%`;
    progressText.textContent = `正在转换... ${Math.round(percent)}%`;
  }

  // 下载全部按钮事件
  downloadAllBtn.addEventListener('click', () => {
    if (convertedResults.length === 0) {
      showToast('暂无可下载的转换结果', 'warning');
      return;
    }
    
    convertedResults.forEach((result, index) => {
      const url = result.convertedUrl;
      const a = document.createElement('a');
      a.href = url;
      a.download = `converted_${index+1}_${result.originalFile.name.replace(/\.[^/.]+$/, "")}.${result.extension.toLowerCase()}`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      // 不立即 revoke URL，因为可能有多次下载
    });

    showToast(`开始下载 ${convertedResults.length} 张转换后的图片`, 'success');

    // 稍后清理 URL 对象
    setTimeout(() => {
      convertedResults.forEach(result => {
        URL.revokeObjectURL(result.convertedUrl);
      });
    }, 1000);
  });

  // 新转换按钮事件
  newConversionBtn.addEventListener('click', () => {
    // 重置所有状态
    fileInput.value = '';
    selectedFiles = [];
    convertedResults = [];
    
    previewList.innerHTML = '';
    previewArea.classList.add('hidden');
    optionsArea.classList.add('hidden');
    progressArea.classList.add('hidden');
    resultArea.classList.add('hidden');
    resultsGrid.innerHTML = '';
    
    updateFileCount();
    showToast('已重置转换状态，可开始新的转换', 'info');
  });
</script>
