

<!-- 转换工具主体 -->
<div class="max-w-4xl mx-auto">
  <div class="bg-white dark:bg-slate-800 rounded-xl p-6 border border-slate-200 dark:border-slate-700 shadow">
    
    <!-- 文件上传区域 -->
    <div id="uploadArea" class="drop-zone">
      <i class="fa-solid fa-cloud-arrow-up text-4xl text-slate-400 mb-3"></i>
      <h3 class="text-lg font-medium mb-1">拖拽图片到此处或点击上传</h3>
      <p class="text-sm text-slate-500 dark:text-slate-400 mb-3">支持 JPG, PNG, WebP, GIF 格式，最多可选 10 张</p>
      <p class="text-xs text-slate-400 dark:text-slate-500">单张最大文件大小: 10MB</p>
      <input type="file" id="fileInput" accept="image/*" class="hidden" multiple>
      <button id="browseBtn" class="mt-4 px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-light transition-colors">
        选择图片
      </button>
    </div>

    <!-- 已选图片预览 -->
    <div id="previewArea" class="mt-4 preview-grid hidden">
      <h3 class="font-medium mb-2 col-span-full">已选择 (<span id="fileCount">0</span>/10)</h3>
      <div id="previewList" class="col-span-full"></div>
    </div>

    <!-- 转换选项 -->
    <div id="optionsArea" class="mt-6 space-y-4 hidden">
      <h3 class="font-medium">转换选项</h3>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium mb-1">输出格式</label>
          <select id="formatSelect" class="w-full p-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700">
            <option value="jpg">JPG</option>
            <option value="png">PNG</option>
            <option value="webp">WebP</option>
            <option value="gif">GIF</option>
          </select>
        </div>
        
        <div>
          <label class="block text-sm font-medium mb-1">JPG质量</label>
          <input type="range" id="qualitySlider" min="10" max="100" value="85" class="w-full">
          <div class="flex justify-between text-xs text-slate-500 dark:text-slate-400">
            <span>较小 (更快)</span>
            <span id="qualityValue">85%</span>
            <span>较好 (更大)</span>
          </div>
        </div>
      </div>

      <button id="convertBtn" class="w-full py-3 bg-secondary text-white rounded-lg hover:opacity-90 transition-opacity font-medium">
        <i class="fa-solid fa-sync-alt mr-2"></i>
        开始批量转换
      </button>
    </div>

    <!-- 进度条 -->
    <div id="progressArea" class="mt-6 hidden">
      <h3 class="font-medium mb-2">转换进度</h3>
      <div class="progress-bar">
        <div id="progressBarFill" class="progress-bar-fill"></div>
      </div>
      <p id="progressText" class="text-center text-sm mt-2 text-slate-600 dark:text-slate-300">准备中...</p>
      <p id="progressDetail" class="text-center text-xs mt-1 text-slate-500 dark:text-slate-400"></p>
    </div>

    <!-- 结果展示区域 -->
    <div id="resultArea" class="mt-6 hidden">
      <h3 class="font-medium mb-4">转换结果</h3>
      
      <div id="resultsGrid" class="preview-grid">
        <!-- 转换结果项将动态插入这里 -->
      </div>

      <div class="mt-6 text-center">
        <button id="downloadAllBtn" class="px-6 py-2.5 bg-primary text-white rounded-lg hover:bg-primary-light transition-colors font-medium">
          <i class="fa-solid fa-download mr-2"></i>
          下载全部
        </button>
        <button id="newConversionBtn" class="ml-3 px-4 py-2.5 border border-slate-300 dark:border-slate-600 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">
          <i class="fa-solid fa-plus mr-1"></i>
          新转换
        </button>
      </div>
    </div>
  </div>

  <!-- 特点介绍 -->
  <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-white dark:bg-slate-800 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
      <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
        <i class="fa-solid fa-layer-group"></i>
      </div>
      <h4 class="font-medium mb-1">批量处理</h4>
      <p class="text-sm text-slate-600 dark:text-slate-400">一次性上传最多10张图片，高效完成批量格式转换任务。</p>
    </div>
    <div class="bg-white dark:bg-slate-800 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
      <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
        <i class="fa-solid fa-sliders"></i>
      </div>
      <h4 class="font-medium mb-1">灵活输出</h4>
      <p class="text-sm text-slate-600 dark:text-slate-400">支持JPG、PNG、WebP、GIF四种主流格式自由转换。</p>
    </div>
    <div class="bg-white dark:bg-slate-800 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
      <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
        <i class="fa-solid fa-shield-alt"></i>
      </div>
      <h4 class="font-medium mb-1">安全高效</h4>
      <p class="text-sm text-slate-600 dark:text-slate-400">所有处理均在浏览器内完成，保护您的隐私安全，无需上传服务器。</p>
    </div>
  </div>
</div>



