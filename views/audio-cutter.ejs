<script>
  // 导入FFmpeg
  const { fetchFile } = FFmpegUtil;
  const { FFmpeg } = FFmpegWASM;

  // DOM 元素获取
  const fileInput = document.getElementById('fileInput');
  const browseBtn = document.getElementById('browseBtn');
  const uploadArea = document.getElementById('uploadArea');
  const playerArea = document.getElementById('playerArea');
  const audioPlayer = document.getElementById('audioPlayer');
  const progressContainer = document.getElementById('progressContainer');
  const cropRange = document.getElementById('cropRange');
  const startHandle = document.getElementById('startHandle');
  const endHandle = document.getElementById('endHandle');
  const startTime = document.getElementById('startTime');
  const endTime = document.getElementById('endTime');
  const startTimeInput = document.getElementById('startTimeInput');
  const endTimeInput = document.getElementById('endTimeInput');
  const cutBtn = document.getElementById('cutBtn');
  const progressArea = document.getElementById('progressArea');
  const progressBarFill = document.getElementById('progressBarFill');
  const progressText = document.getElementById('progressText');
  const resultArea = document.getElementById('resultArea');
  const croppedAudio = document.getElementById('croppedAudio');
  const downloadBtn = document.getElementById('downloadBtn');
  const newCutBtn = document.getElementById('newCutBtn');

  let selectedFile = null;
  let ffmpeg = null;
  let isDragging = false;
  let draggingHandle = null;
  let startPercent = 0;
  let endPercent = 100;
  let totalDuration = 0;

  // 文件浏览按钮点击事件
  browseBtn.addEventListener('click', () => {
    console.log('点击了文件浏览按钮');
    fileInput.click();
  });

  // 文件输入变化事件
  fileInput.addEventListener('change', (e) => {
    if (e.target.files.length > 0) {
      handleFileSelect(e.target.files[0]);
    }
  });

  // 拖拽上传事件
  uploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadArea.classList.add('border-primary', 'bg-primary/10');
  });

  uploadArea.addEventListener('dragleave', () => {
    uploadArea.classList.remove('border-primary', 'bg-primary/10');
  });

  uploadArea.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadArea.classList.remove('border-primary', 'bg-primary/10');
    if (e.dataTransfer.files.length > 0) {
      handleFileSelect(e.dataTransfer.files[0]);
    }
  });

  // 处理文件选择
  async function handleFileSelect(file) {
    if (!file.type.startsWith('audio/')) {
      showToast('请选择音频文件', 'error');
      return;
    }

    if (file.size > 50 * 1024 * 1024) {
      showToast('文件大小超出50MB限制', 'error');
      return;
    }

    selectedFile = file;

    // 初始化FFmpeg
    if (!ffmpeg) {
      try {
        ffmpeg = new FFmpeg();
        ffmpeg.on("log", ({ message }) => {
          console.log(message);
        });
        ffmpeg.on("progress", ({ progress }) => {
          console.log(`${progress * 100} %`);
        });
        showToast('正在加载FFmpeg，请稍候...', 'info');
        await ffmpeg.load({
          coreURL: "/assets/core/package/dist/umd/ffmpeg-core.js",
        });
        showToast('FFmpeg加载成功', 'success');
      } catch (error) {
        console.error('FFmpeg加载失败:', error);
        showToast('FFmpeg加载失败，请刷新页面重试', 'error');
        return;
      }
    }

    try {
      // 设置音频播放器
      const objectURL = URL.createObjectURL(file);
      audioPlayer.src = objectURL;

      // 获取音频时长
      const audio = new Audio();
      audio.src = objectURL;
      await new Promise((resolve) => {
        audio.addEventListener('loadedmetadata', () => {
          totalDuration = audio.duration;
          resolve();
        });
      });

      // 更新时间显示
      updateTimeDisplay();

      // 显示播放器区域
      playerArea.classList.remove('hidden');
      showToast('音频加载成功', 'success');
    } catch (error) {
      console.error('音频加载失败:', error);
      showToast('音频加载失败，请重试', 'error');
    }
  }

  // 更新时间显示
  function updateTimeDisplay() {
    const startSeconds = (startPercent / 100) * totalDuration;
    const endSeconds = (endPercent / 100) * totalDuration;

    startTime.textContent = formatTime(startSeconds);
    endTime.textContent = formatTime(endSeconds);
    startTimeInput.value = formatTime(startSeconds);
    endTimeInput.value = formatTime(endSeconds);
  }

  // 格式化时间
  function formatTime(seconds) {
    const mins = Math.floor(seconds / 60);
    const secs = Math.floor(seconds % 60);
    return `${mins}:${secs.toString().padStart(2, '0')}`;
  }

  // 解析时间字符串
  function parseTime(timeStr) {
    const parts = timeStr.split(':');
    if (parts.length === 2) {
      const mins = parseInt(parts[0]) || 0;
      const secs = parseInt(parts[1]) || 0;
      return mins * 60 + secs;
    }
    return 0;
  }

  // 计算鼠标在进度条上的百分比
  function getPercent(e) {
    const rect = progressContainer.getBoundingClientRect();
    let percent = ((e.clientX - rect.left) / rect.width) * 100;
    percent = Math.max(0, Math.min(100, percent));
    return percent;
  }

  // 更新裁切范围
  function updateCropRange() {
    const left = Math.min(startPercent, endPercent);
    const width = Math.abs(endPercent - startPercent);

    cropRange.style.left = `${left}%`;
    cropRange.style.width = `${width}%`;
    startHandle.style.left = `${startPercent}%`;
    endHandle.style.left = `${endPercent}%`;

    updateTimeDisplay();
  }

  // 开始拖拽
  function startDrag(e, handle) {
    isDragging = true;
    draggingHandle = handle;
    document.addEventListener('mousemove', onDrag);
    document.addEventListener('mouseup', stopDrag);
  }

  // 拖拽中
  function onDrag(e) {
    if (!isDragging) return;

    const percent = getPercent(e);

    if (draggingHandle === 'start') {
      startPercent = percent;
      if (startPercent >= endPercent) {
        startPercent = endPercent - 1;
      }
    } else if (draggingHandle === 'end') {
      endPercent = percent;
      if (endPercent <= startPercent) {
        endPercent = startPercent + 1;
      }
    }

    updateCropRange();
  }

  // 停止拖拽
  function stopDrag() {
    isDragging = false;
    draggingHandle = null;
    document.removeEventListener('mousemove', onDrag);
    document.removeEventListener('mouseup', stopDrag);
  }

  // 开始手柄拖拽事件
  startHandle.addEventListener('mousedown', (e) => {
    e.preventDefault();
    startDrag(e, 'start');
  });

  // 结束手柄拖拽事件
  endHandle.addEventListener('mousedown', (e) => {
    e.preventDefault();
    startDrag(e, 'end');
  });

  // 进度条点击事件
  progressContainer.addEventListener('click', (e) => {
    if (!isDragging) {
      const percent = getPercent(e);
      // 点击位置更靠近哪个手柄，就移动哪个
      if (Math.abs(percent - startPercent) < Math.abs(percent - endPercent)) {
        startPercent = percent;
        if (startPercent >= endPercent) {
          startPercent = endPercent - 1;
        }
      } else {
        endPercent = percent;
        if (endPercent <= startPercent) {
          endPercent = startPercent + 1;
        }
      }
      updateCropRange();
    }
  });

  // 时间输入变化事件
  startTimeInput.addEventListener('change', () => {
    const seconds = parseTime(startTimeInput.value);
    const percent = (seconds / totalDuration) * 100;
    startPercent = Math.max(0, Math.min(100, percent));
    if (startPercent >= endPercent) {
      startPercent = endPercent - 1;
    }
    updateCropRange();
  });

  endTimeInput.addEventListener('change', () => {
    const seconds = parseTime(endTimeInput.value);
    const percent = (seconds / totalDuration) * 100;
    endPercent = Math.max(0, Math.min(100, percent));
    if (endPercent <= startPercent) {
      endPercent = startPercent + 1;
    }
    updateCropRange();
  });

  // 使用FFmpeg.wasm裁切音频
  async function cutAudio(startSeconds, endSeconds) {
    return new Promise(async (resolve, reject) => {
      try {
        // 生成输入和输出文件名
        const inputFileName = 'input.audio';
        const outputFileName = 'output.audio';

        // 写入文件到FFmpeg虚拟文件系统
        await ffmpeg.writeFile(inputFileName, await fetchFile(selectedFile));

        // 构建FFmpeg命令
        // -ss: 开始时间
        // -to: 结束时间
        // -i: 输入文件
        // -c copy: 直接复制编码，不重新编码（更快）
        await ffmpeg.exec(['-i', inputFileName, '-ss', startSeconds.toString(), '-to', endSeconds.toString(), '-c', 'copy', outputFileName]);

        // 读取输出文件
        const data = await ffmpeg.readFile(outputFileName);

        // 创建Blob对象
        const mimeType = selectedFile.type;
        const blob = new Blob([data.buffer], { type: mimeType });

        resolve(blob);
      } catch (error) {
        console.error('FFmpeg裁切失败:', error);
        reject(error);
      }
    });
  }

  // 开始裁切按钮事件
  cutBtn.addEventListener('click', async () => {
    if (!selectedFile || !ffmpeg) {
      showToast('请先选择音频文件', 'warning');
      return;
    }

    const startSeconds = (startPercent / 100) * totalDuration;
    const endSeconds = (endPercent / 100) * totalDuration;

    if (endSeconds - startSeconds < 0.1) {
      showToast('裁切范围过小，请调整', 'warning');
      return;
    }

    progressArea.classList.remove('hidden');
    resultArea.classList.add('hidden');

    try {
      progressText.textContent = '正在裁切...';
      progressBarFill.style.width = '0%';

      // 模拟进度
      let progress = 0;
      const progressInterval = setInterval(() => {
        progress += 10;
        progressBarFill.style.width = `${progress}%`;
        if (progress >= 90) {
          clearInterval(progressInterval);
        }
      }, 100);

      // 执行音频裁切
      const croppedBlob = await cutAudio(startSeconds, endSeconds);
      const croppedUrl = URL.createObjectURL(croppedBlob);

      // 更新进度
      clearInterval(progressInterval);
      progressBarFill.style.width = '100%';
      progressText.textContent = '裁切完成！';

      // 设置裁切后音频播放器
      croppedAudio.src = croppedUrl;

      // 显示结果区域
      setTimeout(() => {
        resultArea.classList.remove('hidden');
        progressArea.classList.add('hidden');
        showToast('音频裁切成功', 'success');
      }, 500);

      // 下载按钮事件
      downloadBtn.onclick = () => {
        const a = document.createElement('a');
        a.href = croppedUrl;
        const fileName = selectedFile.name.replace(/\.[^/.]+$/, `_cut.${croppedBlob.type.split('/')[1]}`);
        a.download = fileName;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        showToast(`开始下载 ${fileName}`, 'success');
      };

    } catch (error) {
      console.error('裁切失败:', error);
      progressText.textContent = '裁切失败，请重试。';
      showToast('裁切失败，请重试', 'error');
    }
  });

  // 新裁切按钮事件
  newCutBtn.addEventListener('click', () => {
    fileInput.value = '';
    selectedFile = null;
    startPercent = 0;
    endPercent = 100;
    totalDuration = 0;

    audioPlayer.src = '';
    croppedAudio.src = '';
    updateTimeDisplay();
    updateCropRange();

    playerArea.classList.add('hidden');
    progressArea.classList.add('hidden');
    resultArea.classList.add('hidden');

    showToast('已重置，可开始新的裁切任务', 'info');
  });
</script>