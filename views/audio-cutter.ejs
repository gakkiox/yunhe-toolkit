<!-- 音频裁切工具主体 -->
<div class="max-w-4xl mx-auto">
  <div class="bg-white dark:bg-slate-800 rounded-xl p-6 border border-slate-200 dark:border-slate-700 shadow">

    <!-- 文件上传区域 -->
    <div id="uploadArea"
      class="drop-zone border-2 border-dashed border-slate-200 dark:border-slate-700 rounded-lg p-8 text-center cursor-pointer transition-colors duration-200">
      <i class="fa-solid fa-music text-4xl text-slate-400 mb-3"></i>
      <h3 class="text-lg font-medium mb-1">拖拽音频到此处或点击上传</h3>
      <p class="text-sm text-slate-500 dark:text-slate-400 mb-3">支持 MP3, WAV, OGG, AAC 格式</p>
      <p class="text-xs text-slate-400 dark:text-slate-500">单个文件最大大小: 50MB</p>
      <input type="file" id="fileInput" accept="audio/*" class="hidden">
      <button id="browseBtn"
        class="mt-4 px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-light transition-colors">
        选择音频
      </button>
    </div>

    <!-- 音频播放器和裁切控制 -->
    <div id="playerArea" class="mt-6 hidden">
      <h3 class="font-medium mb-3">音频预览与裁切</h3>

      <div class="bg-slate-100 dark:bg-slate-700 rounded-lg p-4">
        <!-- 音频播放器 -->
        <div class="mb-4">
          <audio id="audioPlayer" controls class="w-full">
            您的浏览器不支持音频播放。
          </audio>
        </div>

        <!-- 裁切范围控制 -->
        <div class="mb-4">
          <div class="flex justify-between text-sm text-slate-600 dark:text-slate-400 mb-1">
            <span>开始时间: <span id="startTime">0:00</span></span>
            <span>结束时间: <span id="endTime">0:00</span></span>
          </div>

          <!-- 进度条 -->
          <div id="progressContainer" class="relative h-6 bg-slate-200 dark:bg-slate-600 rounded-full cursor-pointer">
            <!-- 裁切范围 -->
            <div id="cropRange" class="absolute top-0 h-full bg-primary/30 rounded-full" style="left: 0%; width: 100%">
            </div>

            <!-- 开始拖拽手柄 -->
            <div id="startHandle"
              class="absolute top-1/2 transform -translate-y-1/2 w-4 h-4 bg-primary rounded-full cursor-col-resize">
            </div>

            <!-- 结束拖拽手柄 -->
            <div id="endHandle"
              class="absolute top-1/2 transform -translate-y-1/2 w-4 h-4 bg-primary rounded-full cursor-col-resize">
            </div>
          </div>
        </div>

        <!-- 时间输入 -->
        <div class="grid grid-cols-2 gap-4 mb-4">
          <div>
            <label class="block text-sm font-medium mb-1">开始时间</label>
            <input type="text" id="startTimeInput"
              class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-slate-100"
              placeholder="0:00">
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">结束时间</label>
            <input type="text" id="endTimeInput"
              class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-slate-100"
              placeholder="0:00">
          </div>
        </div>

        <button id="cutBtn"
          class="w-full py-3 bg-primary text-white rounded-lg hover:opacity-90 transition-opacity font-medium">
          <i class="fa-solid fa-cut mr-2"></i>
          开始裁切
        </button>
      </div>
    </div>

    <!-- 进度条 -->
    <div id="progressArea" class="mt-6 hidden">
      <h3 class="font-medium mb-2">裁切进度</h3>
      <div class="h-3 w-full bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden">
        <div id="progressBarFill" class="h-full bg-primary dark:bg-primary-light w-0 transition-all duration-300"></div>
      </div>
      <p id="progressText" class="text-center text-sm mt-2 text-slate-600 dark:text-slate-300">准备中...</p>
    </div>

    <!-- 结果展示区域 -->
    <div id="resultArea" class="mt-6 hidden">
      <h3 class="font-medium mb-4">裁切结果</h3>

      <div class="bg-slate-100 dark:bg-slate-700 rounded-lg p-4">
        <!-- 裁切后音频预览 -->
        <div class="mb-4">
          <h4 class="text-sm font-medium mb-2">裁切后音频</h4>
          <audio id="croppedAudio" controls class="w-full">
            您的浏览器不支持音频播放。
          </audio>
        </div>

        <div class="flex space-x-2">
          <button id="downloadBtn"
            class="flex-1 py-2.5 bg-primary text-white rounded-lg hover:bg-primary-light transition-colors font-medium">
            <i class="fa-solid fa-download mr-2"></i>
            下载
          </button>
          <button id="newCutBtn"
            class="flex-1 py-2.5 border border-slate-300 dark:border-slate-600 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">
            <i class="fa-solid fa-plus mr-1"></i>
            新裁切
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- 特点介绍 -->
  <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-white dark:bg-slate-800 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
      <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
        <i class="fa-solid fa-sliders"></i>
      </div>
      <h4 class="font-medium mb-1">精确控制</h4>
      <p class="text-sm text-slate-600 dark:text-slate-400">通过拖动进度条或输入时间，精确控制裁切范围。</p>
    </div>
    <div class="bg-white dark:bg-slate-800 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
      <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
        <i class="fa-solid fa-bolt"></i>
      </div>
      <h4 class="font-medium mb-1">快速处理</h4>
      <p class="text-sm text-slate-600 dark:text-slate-400">本地浏览器处理，无需上传服务器，裁切速度快。</p>
    </div>
    <div class="bg-white dark:bg-slate-800 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
      <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
        <i class="fa-solid fa-lock"></i>
      </div>
      <h4 class="font-medium mb-1">安全隐私</h4>
      <p class="text-sm text-slate-600 dark:text-slate-400">所有处理在本地完成，保护您的音频文件安全。</p>
    </div>
  </div>
</div>
