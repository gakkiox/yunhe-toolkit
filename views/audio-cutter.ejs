<!-- 音频裁切工具主体 -->
<div class="max-w-4xl mx-auto">
  <div class="bg-white dark:bg-slate-800 rounded-xl p-6 border border-slate-200 dark:border-slate-700 shadow">
    
    <!-- 文件上传区域 -->
    <div id="uploadArea" class="drop-zone border-2 border-dashed border-slate-200 dark:border-slate-700 rounded-lg p-8 text-center cursor-pointer transition-colors duration-200">
      <i class="fa-solid fa-music text-4xl text-slate-400 mb-3"></i>
      <h3 class="text-lg font-medium mb-1">拖拽音频到此处或点击上传</h3>
      <p class="text-sm text-slate-500 dark:text-slate-400 mb-3">支持 MP3, WAV, OGG, AAC 格式</p>
      <p class="text-xs text-slate-400 dark:text-slate-500">单个文件最大大小: 50MB</p>
      <input type="file" id="fileInput" accept="audio/*" class="hidden">
      <button id="browseBtn" class="mt-4 px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-light transition-colors">
        选择音频
      </button>
    </div>

    <!-- 音频预览和裁切控制 -->
    <div id="cutterArea" class="mt-6 hidden">
      <!-- 音频播放器 -->
      <div class="bg-slate-100 dark:bg-slate-700 rounded-lg p-4 mb-4">
        <audio id="audioPlayer" controls class="w-full"></audio>
      </div>

      <!-- 裁切时间设置 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
        <div>
          <label class="block text-sm font-medium mb-1">开始时间</label>
          <input type="time" id="startTime" step="0.001" class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-slate-100">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">结束时间</label>
          <input type="time" id="endTime" step="0.001" class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-slate-100">
        </div>
      </div>

      <!-- 时间轴 -->
      <div class="mb-6">
        <label class="block text-sm font-medium mb-2">裁切区域</label>
        <div class="relative">
          <input type="range" id="timeSlider" min="0" max="100" value="0" class="w-full h-2 bg-slate-200 dark:bg-slate-700 rounded-lg appearance-none cursor-pointer">
          <div id="selectionRange" class="absolute top-0 left-0 h-2 bg-primary/30 rounded-lg pointer-events-none"></div>
          <div id="startHandle" class="absolute top-[-5px] w-3 h-3 bg-primary rounded-full cursor-pointer" style="transform: translateX(-50%);"></div>
          <div id="endHandle" class="absolute top-[-5px] w-3 h-3 bg-primary rounded-full cursor-pointer" style="transform: translateX(-50%);"></div>
        </div>
        <div class="flex justify-between text-xs text-slate-500 dark:text-slate-400 mt-1">
          <span id="currentTime">00:00.000</span>
          <span id="duration">00:00.000</span>
        </div>
      </div>

      <!-- 输出格式 -->
      <div class="mb-6">
        <label class="block text-sm font-medium mb-1">输出格式</label>
        <select id="outputFormat" class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-slate-100">
          <option value="mp3">MP3</option>
          <option value="wav">WAV</option>
          <option value="ogg">OGG</option>
          <option value="aac">AAC</option>
        </select>
      </div>

      <button id="cutBtn" class="w-full py-3 bg-primary text-white rounded-lg hover:opacity-90 transition-opacity font-medium">
        <i class="fa-solid fa-cut mr-2"></i>
        开始裁切
      </button>
    </div>

    <!-- 进度条 -->
    <div id="progressArea" class="mt-6 hidden">
      <h3 class="font-medium mb-2">裁切进度</h3>
      <div class="h-3 w-full bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden">
        <div id="progressBarFill" class="h-full bg-primary dark:bg-primary-light w-0 transition-all duration-300"></div>
      </div>
      <p id="progressText" class="text-center text-sm mt-2 text-slate-600 dark:text-slate-300">准备中...</p>
    </div>

    <!-- 结果展示区域 -->
    <div id="resultArea" class="mt-6 hidden">
      <h3 class="font-medium mb-4">裁切结果</h3>
      
      <div class="bg-slate-100 dark:bg-slate-700 rounded-lg p-4 mb-4">
        <h4 class="text-sm font-medium mb-2">预览</h4>
        <audio id="resultPlayer" controls class="w-full"></audio>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
        <div class="bg-slate-100 dark:bg-slate-700 rounded-lg p-4">
          <h4 class="text-sm font-medium mb-2">原文件信息</h4>
          <p class="text-xs text-slate-600 dark:text-slate-400" id="originalInfo"></p>
        </div>
        <div class="bg-slate-100 dark:bg-slate-700 rounded-lg p-4">
          <h4 class="text-sm font-medium mb-2">裁切后信息</h4>
          <p class="text-xs text-slate-600 dark:text-slate-400" id="cutInfo"></p>
        </div>
      </div>

      <div class="mt-6 text-center">
        <button id="downloadBtn" class="px-6 py-2.5 bg-primary text-white rounded-lg hover:bg-primary-light transition-colors font-medium">
          <i class="fa-solid fa-download mr-2"></i>
          下载裁切结果
        </button>
        <button id="newCutBtn" class="ml-3 px-4 py-2.5 border border-slate-300 dark:border-slate-600 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">
          <i class="fa-solid fa-plus mr-1"></i>
          新裁切
        </button>
      </div>
    </div>
  </div>

  <!-- 特点介绍 -->
  <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-white dark:bg-slate-800 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
      <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
        <i class="fa-solid fa-sliders"></i>
      </div>
      <h4 class="font-medium mb-1">精确控制</h4>
      <p class="text-sm text-slate-600 dark:text-slate-400">支持精确到毫秒的时间设置，确保裁切准确。</p>
    </div>
    <div class="bg-white dark:bg-slate-800 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
      <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
        <i class="fa-solid fa-play"></i>
      </div>
      <h4 class="font-medium mb-1">实时预览</h4>
      <p class="text-sm text-slate-600 dark:text-slate-400">支持音频预览和裁切区域可视化，直观调整。</p>
    </div>
    <div class="bg-white dark:bg-slate-800 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
      <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
        <i class="fa-solid fa-bolt"></i>
      </div>
      <h4 class="font-medium mb-1">安全高效</h4>
      <p class="text-sm text-slate-600 dark:text-slate-400">所有处理在本地浏览器完成，保护您的隐私安全。</p>
    </div>
  </div>
</div>
