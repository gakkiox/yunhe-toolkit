<script>
  // JSON格式化工具功能
const inputJson = document.getElementById('inputJson');
const outputJson = document.getElementById('outputJson');
const formatBtn = document.getElementById('formatBtn');
const compressBtn = document.getElementById('compressBtn');
const validateBtn = document.getElementById('validateBtn');
const clearInput = document.getElementById('clearInput');
const copyOutput = document.getElementById('copyOutput');

// 语法高亮函数
function syntaxHighlight(json) {
  if (typeof json !== 'string') return '';
  
  return json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    .replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g, function(match) {
      let cls = 'json-punctuation'; // 默认标点符号
      
      if (/^"/.test(match)) {
        if (/:$/.test(match)) {
          cls = 'json-key'; // 键名
        } else {
          cls = 'json-string'; // 字符串值
        }
      } else if (/true|false/.test(match)) {
        cls = 'json-boolean'; // 布尔值
      } else if (/null/.test(match)) {
        cls = 'json-null'; // null值
      } else if (/^-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?$/.test(match)) {
        cls = 'json-number'; // 数字
      }
      
      return '<span class="' + cls + '">' + match + '</span>';
    });
}

// 格式化JSON
function formatJson() {
  try {
    const input = inputJson.value.trim();
    if (!input) {
      showToast('请输入JSON数据', 'warning');
      return;
    }
    
    const parsed = JSON.parse(input);
    const formatted = JSON.stringify(parsed, null, 2);
    outputJson.innerHTML = syntaxHighlight(formatted);
    showToast('格式化成功！', 'success');
  } catch (error) {
    showToast(`格式化失败: ${error.message}`, 'error');
  }
}

// 压缩JSON
function compressJson() {
  try {
    const input = inputJson.value.trim();
    if (!input) {
      showToast('请输入JSON数据', 'warning');
      return;
    }
    
    const parsed = JSON.parse(input);
    const compressed = JSON.stringify(parsed);
    outputJson.innerHTML = syntaxHighlight(compressed);
    showToast('压缩成功！', 'success');
  } catch (error) {
    showToast(`压缩失败: ${error.message}`, 'error');
  }
}

// 验证JSON
function validateJson() {
  try {
    const input = inputJson.value.trim();
    if (!input) {
      showToast('请输入JSON数据', 'warning');
      return;
    }
    
    JSON.parse(input);
    showToast('JSON格式有效！', 'success');
  } catch (error) {
    showToast(`JSON格式无效: ${error.message}`, 'error');
  }
}

// 清空输入
function clearInputField() {
  inputJson.value = '';
  outputJson.innerHTML = '';
  showToast('已清空', 'info');
}

// 复制输出
async function copyOutputText() {
  try {
    const text = outputJson.innerText || outputJson.textContent;
    await navigator.clipboard.writeText(text);
    showToast('已复制到剪贴板！', 'success');
  } catch (err) {
    showToast('复制失败，请手动复制', 'error');
  }
}

// 事件监听器
formatBtn.addEventListener('click', formatJson);
compressBtn.addEventListener('click', compressJson);
validateBtn.addEventListener('click', validateJson);
clearInput.addEventListener('click', clearInputField);
copyOutput.addEventListener('click', copyOutputText);

// 输入框实时验证（可选）
inputJson.addEventListener('input', () => {
  if (inputJson.value.trim() === '') {
    outputJson.innerHTML = '';
  }
});
</script>

