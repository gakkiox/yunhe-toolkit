<script src="/js/jszip.min.js"></script>
<script>
  // DOM 元素获取
  const fileInput = document.getElementById('fileInput');
  const browseBtn = document.getElementById('browseBtn');
  const uploadArea = document.getElementById('uploadArea');
  const previewArea = document.getElementById('previewArea');
  const previewList = document.getElementById('previewList');
  const fileCount = document.getElementById('fileCount');
  const optionsArea = document.getElementById('optionsArea');
  const convertBtn = document.getElementById('convertBtn');
  const progressArea = document.getElementById('progressArea');
  const progressBarFill = document.getElementById('progressBarFill');
  const progressText = document.getElementById('progressText');
  const progressDetail = document.getElementById('progressDetail');
  const resultArea = document.getElementById('resultArea');
  const resultsGrid = document.getElementById('resultsGrid');
  const downloadAllBtn = document.getElementById('downloadAllBtn');
  const newConversionBtn = document.getElementById('newConversionBtn');
  const outputFormat = document.getElementById('outputFormat');
  const audioQuality = document.getElementById('audioQuality');

  let selectedFiles = [];
  let conversionResults = [];
  const MAX_FILE_SIZE = 50 * 1024 * 1024; // 50MB 限制
  const SUPPORTED_FORMATS = ['audio/mpeg', 'audio/wav', 'audio/ogg', 'audio/aac'];
  const SUPPORTED_FORMAT_NAMES = ['MP3', 'WAV', 'OGG', 'AAC'];

  // 文件浏览按钮点击事件
  browseBtn.addEventListener('click', () => {
    fileInput.click();
  });

  // 文件输入变化事件
  fileInput.addEventListener('change', (e) => {
    handleFileSelect(Array.from(e.target.files));
  });

  // 拖拽上传事件
  uploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadArea.classList.add('border-primary', 'bg-primary/10');
  });

  uploadArea.addEventListener('dragleave', () => {
    uploadArea.classList.remove('border-primary', 'bg-primary/10');
  });

  uploadArea.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadArea.classList.remove('border-primary', 'bg-primary/10');
    handleFileSelect(Array.from(e.dataTransfer.files));
  });

  // 处理文件选择
  function handleFileSelect(files) {
    const validFiles = [];
    files.forEach(file => {
      if (!SUPPORTED_FORMATS.includes(file.type)) {
        showToast(`文件 ${file.name} 格式不支持（仅支持${SUPPORTED_FORMAT_NAMES.join(', ')}）`, 'error');
        return;
      }
      if (file.size > MAX_FILE_SIZE) {
        showToast(`文件 ${file.name} 大小超出50MB限制，已跳过`, 'error');
        return;
      }
      validFiles.push(file);
    });

    const totalFiles = selectedFiles.length + validFiles.length;
    if (totalFiles > 10) {
      showToast(`最多只能选择10个音频文件，当前已选择 ${selectedFiles.length} 个，本次添加 ${validFiles.length} 个，总计超出了限制。`, 'error');
      const addCount = 10 - selectedFiles.length;
      selectedFiles.push(...validFiles.slice(0, addCount));
    } else {
      selectedFiles.push(...validFiles);
    }

    renderPreviewList();
    updateFileCount();

    if (selectedFiles.length > 0) {
      optionsArea.classList.remove('hidden');
      if (validFiles.length > 0) {
        showToast(`成功添加 ${validFiles.length} 个音频文件`, 'success');
      }
    }
  }

  // 渲染预览列表
  function renderPreviewList() {
    previewList.innerHTML = '';
    selectedFiles.forEach((file, index) => {
      const item = document.createElement('div');
      item.className = 'bg-slate-100 dark:bg-slate-700 rounded-lg p-3';
      item.innerHTML = `
        <div class="flex items-center mb-2">
          <i class="fa-solid fa-file-audio text-primary mr-2"></i>
          <h4 class="text-sm font-medium truncate">${file.name}</h4>
        </div>
        <div class="text-xs text-slate-600 dark:text-slate-400 mb-2">
          ${formatFileSize(file.size)}
        </div>
        <button class="remove-btn w-full py-1 text-xs text-red-600 dark:text-red-400 hover:underline" data-index="${index}">
          移除
        </button>
      `;
      previewList.appendChild(item);

      // 移除按钮事件
      item.querySelector('.remove-btn').addEventListener('click', (e) => {
        e.stopPropagation();
        removeFile(index);
      });
    });
    previewArea.classList.remove('hidden');
  }

  // 移除文件
  function removeFile(index) {
    const removedFileName = selectedFiles[index].name;
    selectedFiles.splice(index, 1);
    renderPreviewList();
    updateFileCount();

    showToast(`已移除 ${removedFileName}`, 'info');

    if (selectedFiles.length === 0) {
      optionsArea.classList.add('hidden');
    }
  }

  // 更新文件计数
  function updateFileCount() {
    fileCount.textContent = selectedFiles.length;
  }

  // 格式化文件大小
  function formatFileSize(bytes) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
  }

  // 开始批量转换按钮事件
  convertBtn.addEventListener('click', async () => {
    if (selectedFiles.length === 0) {
      showToast('请先选择要转换的音频文件', 'warning');
      return;
    }

    progressArea.classList.remove('hidden');
    resultArea.classList.add('hidden');
    resultsGrid.innerHTML = '';
    conversionResults = [];

    try {
      let processed = 0;
      const total = selectedFiles.length;

      for (let i = 0; i < selectedFiles.length; i++) {
        const file = selectedFiles[i];
        
        progressDetail.textContent = `正在处理: ${file.name}`;
        updateProgress(((i) / total) * 100);

        try {
          const convertedBlob = await simulateConversion(file, outputFormat.value, audioQuality.value);
          const convertedUrl = URL.createObjectURL(convertedBlob);
          
          const originalSize = file.size;
          const convertedSize = convertedBlob.size;
          const sizeChange = ((convertedSize / originalSize - 1) * 100).toFixed(1);
          
          conversionResults.push({
            originalFile: file,
            convertedBlob: convertedBlob,
            convertedUrl: convertedUrl,
            originalSize: originalSize,
            convertedSize: convertedSize,
            sizeChange: sizeChange,
            outputFormat: outputFormat.value
          });

          processed++;
          updateProgress((processed / total) * 100);
        } catch (fileError) {
          console.error(`转换文件 ${file.name} 失败:`, fileError);
          showToast(`文件 ${file.name} 转换失败，跳过该文件`, 'error');
          processed++;
          updateProgress((processed / total) * 100);
        }
      }

      progressText.textContent = '全部转换完成！';
      progressDetail.textContent = '';
      
      if (conversionResults.length > 0) {
        showToast(`成功转换 ${conversionResults.length} 个音频文件（${selectedFiles.length - conversionResults.length} 个失败）`, 'success');
        renderResults();
        setTimeout(() => {
          resultArea.classList.remove('hidden');
          progressArea.classList.add('hidden');
        }, 500);
      } else {
        showToast('所有音频文件转换失败，请检查文件格式或重试', 'error');
        progressArea.classList.add('hidden');
      }

    } catch (error) {
      console.error('批量转换失败:', error);
      progressText.textContent = '转换过程中出现错误，请重试。';
      progressDetail.textContent = '';
      showToast('转换过程中出现错误，请重试', 'error');
    }
  });

  // 模拟转换函数（实际项目中需要使用Web Audio API或其他库）
  async function simulateConversion(file, format, quality) {
    return new Promise((resolve) => {
      // 模拟转换过程
      setTimeout(() => {
        // 这里只是模拟，实际项目中需要实现真实的音频转换
        // 可以使用Web Audio API或者第三方库如librosa.js等
        resolve(file);
      }, 1000);
    });
  }

  // 渲染转换结果
  function renderResults() {
      resultsGrid.innerHTML = '';
      conversionResults.forEach((result, index) => {
          const item = document.createElement('div');
          item.className = 'bg-slate-100 dark:bg-slate-700 rounded-lg p-3';
          item.innerHTML = `
            <div class="flex items-center mb-2">
              <i class="fa-solid fa-file-audio text-primary mr-2"></i>
              <h4 class="text-sm font-medium truncate">${result.originalFile.name}</h4>
            </div>
            <div class="text-xs text-slate-600 dark:text-slate-400 mb-2">
              转换为 ${result.outputFormat.toUpperCase()}<br>
              ${formatFileSize(result.convertedSize)}
              ${parseFloat(result.sizeChange) > 0 ? `(+${result.sizeChange}%)` : `(${result.sizeChange}%)`}
            </div>
            <audio controls class="w-full mb-2">
              <source src="${result.convertedUrl}" type="audio/${result.outputFormat}">
              您的浏览器不支持音频播放。
            </audio>
            <button class="download-single-btn w-full py-1 text-xs bg-primary text-white rounded hover:bg-primary-light transition-colors" data-index="${index}">
              下载
            </button>
          `;
          resultsGrid.appendChild(item);

          // 单张下载事件
          const downloadBtn = item.querySelector('.download-single-btn');
          downloadBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            downloadSingleAudio(index);
          });
      });
  }

  // 单张音频下载方法
  function downloadSingleAudio(index) {
    const result = conversionResults[index];
    const a = document.createElement('a');
    a.href = result.convertedUrl;
    const fileName = result.originalFile.name.replace(/\.[^/.]+$/, `_converted.${result.outputFormat}`);
    a.download = fileName;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    
    // Toast提示
    showToast(`开始下载 ${fileName}`, 'success');
    
    // 清理URL对象（延迟执行，避免下载中断）
    setTimeout(() => {
      URL.revokeObjectURL(result.convertedUrl);
    }, 1000);
  }

  // 更新进度
  function updateProgress(percent) {
    progressBarFill.style.width = `${percent}%`;
    progressText.textContent = `正在转换... ${Math.round(percent)}%`;
  }

  // 下载全部按钮事件
  downloadAllBtn.addEventListener('click', async () => {
    if (conversionResults.length === 0) {
      showToast('暂无转换文件可下载', 'warning');
      return;
    }

    if (conversionResults.length === 1) {
      downloadSingleAudio(0);
      return;
    }

    try {
      showToast('正在生成压缩包，请稍候...', 'info');
      const zip = new JSZip();
      
      conversionResults.forEach((result, index) => {
        const fileName = result.originalFile.name.replace(/\.[^/.]+$/, `_converted_${index+1}.${result.outputFormat}`);
        zip.file(fileName, result.convertedBlob);
      });

      const zipContent = await zip.generateAsync({
        type: 'blob',
        compression: 'DEFLATE',
        compressionOptions: { level: 6 }
      });

      const zipUrl = URL.createObjectURL(zipContent);
      const a = document.createElement('a');
      a.href = zipUrl;
      a.download = `converted_audio_${new Date().getTime()}.zip`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);

      showToast(`开始下载压缩包（包含 ${conversionResults.length} 个音频文件）`, 'success');

      setTimeout(() => {
        URL.revokeObjectURL(zipUrl);
        conversionResults.forEach(result => {
          URL.revokeObjectURL(result.convertedUrl);
        });
      }, 1000);
    } catch (error) {
      console.error('生成压缩包失败:', error);
      showToast('生成压缩包失败，请尝试单独下载', 'error');
    }
  });

  // 新转换按钮事件
  newConversionBtn.addEventListener('click', () => {
    fileInput.value = '';
    selectedFiles = [];
    conversionResults = [];
    
    previewList.innerHTML = '';
    previewArea.classList.add('hidden');
    optionsArea.classList.add('hidden');
    progressArea.classList.add('hidden');
    resultArea.classList.add('hidden');
    resultsGrid.innerHTML = '';
    
    updateFileCount();
    
    showToast('已重置，可开始新的转换任务', 'info');
  });
</script>